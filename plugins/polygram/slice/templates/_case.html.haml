.case{"data-case-id": caze.id, class: caze.css_class }
  .head
    .title
      %a{href: path(:backend_polygram_show, id: caze.id)} ↳
      = caze.title
      %small
        by
        %strong #{caze.user.name}  

    .checkbox
      .files-attached
        %strong= caze.media.size
        attachment(s)


    - if menu
      .case-menu
        = render "case-menu", caze: caze

  - if menu
    %h4 Attached Media Files

    .media-line
      %ul
        - caze.media.each do |cm|
          %li
            .media-line-entry
              %a.media-detach-link{onclick: "return confirm('#{t.be.polygram.confirmdetach}')", href: path(:backend_polygram_detach, id: caze.id, mid: cm.id) } X

              %span
                Mediasample
                %code= cm.title
              = render "media-links", caze: caze, mid: cm.id
            
            .media-entry{style: "display: #{complete ? 'block' : 'none'}" }
              = render "video", caze: caze, media: cm
