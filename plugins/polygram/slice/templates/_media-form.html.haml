.formbox
  %form{method: :post, action: action, enctype: 'multipart/form-data'}
    = _csrf_field
    %input.form-input{type: :hidden, value: (caze && caze.id ? caze.id : ""), name: :id}
    %textarea{name: :text}= text

    .columns.mtop
      .column.col-10
      .column.col-2.col-mx-auto
        %input.form-input{type: :submit, value: t.form.submit}
